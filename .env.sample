# rekipedia environment variables
# Copy this file to .env and fill in the values you need.
# All variables are optional — they override the settings in .rekipedia/config.yml.

# LLM model (any litellm model string)
# Examples: gpt-5.5 | claude-opus-4-7 | gemini/gemini-2.5-pro | ollama/llama4
REKIPEDIA_MODEL=ollama/llama4

# API key for the chosen provider (leave blank for local models like Ollama)
REKIPEDIA_API_KEY=

# Custom base URL for self-hosted or proxied endpoints
REKIPEDIA_BASE_URL=

# Optional provider-native keys (LiteLLM can read these directly)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
