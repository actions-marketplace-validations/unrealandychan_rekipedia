# Rekipedia Docker Sandbox
#
# This image is used for isolated static analysis only.
# It runs with --network none at runtime — NO LLM calls happen inside.
# Build: docker build -f Dockerfile.sandbox -t rekipedia-sandbox:latest .
# The image is NOT required for normal use; LocalRunner is the fallback.

FROM python:3.12-slim

# --- dependencies (only what the extractors need) ---
RUN pip install --no-cache-dir \
    pydantic>=2.0 \
    pathspec>=0.12 \
    pyyaml>=6.0 \
    tree-sitter>=0.21 \
    tree-sitter-go \
    tree-sitter-python \
    tree-sitter-typescript \
    tree-sitter-rust \
    tree-sitter-java

# --- copy only the code needed for static analysis ---
WORKDIR /app

COPY src/rekipedia/__init__.py         ./rekipedia/__init__.py
COPY src/rekipedia/models/             ./rekipedia/models/
COPY src/rekipedia/extractors/         ./rekipedia/extractors/
COPY src/rekipedia/sandbox/tasks/      ./rekipedia/sandbox/tasks/

# Ensure the package is importable
ENV PYTHONPATH=/app

# Default entrypoint — caller overrides with explicit args
ENTRYPOINT ["python3", "/app/rekipedia/sandbox/tasks/analyze_shard.py"]
